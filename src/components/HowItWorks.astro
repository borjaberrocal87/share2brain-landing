---
import { HowItWorksLoop } from './HowItWorksLoop';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const stepsEs = [
  { k: 'Razonar', d: 'El runtime compone el contexto completo —system prompt, tools disponibles, historial y fragmentos recuperados— y llama al modelo para decidir el siguiente paso.', label: 'Paso 01 · razonar' },
  { k: 'Actuar', d: 'Si el modelo necesita información, solicita una tool. El runtime valida los argumentos contra su esquema Zod antes de ejecutarla. El modelo nunca toca la infraestructura directamente.', label: 'Paso 02 · actuar' },
  { k: 'Observar', d: 'El resultado vuelve al contexto como observación. El bucle continúa hasta que el agente tiene suficiente información para dar una respuesta fundamentada.', label: 'Paso 03 · observar' },
];

const stepsEn = [
  { k: 'Reason', d: 'The runtime assembles the full context —system prompt, available tools, history and retrieved chunks— and calls the model to decide the next step.', label: 'Step 01 · reason' },
  { k: 'Act', d: 'If the model needs information, it requests a tool. The runtime validates arguments against its Zod schema before executing. The model never touches infrastructure directly.', label: 'Step 02 · act' },
  { k: 'Observe', d: 'The result returns to the context as an observation. The loop continues until the agent has enough information to give a grounded answer.', label: 'Step 03 · observe' },
];

const stepsRaw = lang === 'es' ? stepsEs : stepsEn;

const stepsWithCode = stepsRaw.map((step, i) => ({
  ...step,
  code: [
    `# LangGraph · agent runtime`,
    i === 0 ? `await runtime.buildContext({` : i === 1 ? `await runtime.executeTool({` : `// Observation returned`,
    i === 0 ? `  systemPrompt, tools, history, chunks` : i === 1 ? `  name: toolName, args: validatedArgs` : `// Loop continues until done`,
    i === 0 ? `});` : i === 1 ? `});` : `// max_iterations reached`,
  ],
}));
---

<section
  id="how"
  style={{
    backgroundColor: 'var(--surface-2)',
    borderTop: '1px solid var(--border)',
    borderBottom: '1px solid var(--border)',
  }}
  aria-labelledby="how-title"
>
  <div class="max-w-[1180px] mx-auto px-6 py-[clamp(56px,7vw,96px)]">
    <div class="text-center mb-12">
      <p class="font-mono text-sm font-semibold mb-3" style={{ color: 'var(--accent-ink)' }}>
        // <span data-i18n="howKicker">{lang === 'es' ? 'cómo funciona' : 'how it works'}</span>
      </p>
      <h2 
        id="how-title"
        class="font-heading font-bold text-[clamp(28px,3.6vw,42px)] tracking-tight m-0 mx-auto max-w-[20ch]"
      >
        <span data-i18n="howTitle">{lang === 'es' ? 'Un agente que razona, no un bot que repite' : 'An agent that reasons, not a bot that repeats'}</span>
      </h2>
      <p class="text-base leading-relaxed max-w-[60ch] mt-4 mx-auto" style={{ color: 'var(--muted)' }}>
        <span data-i18n="howSub">{lang === 'es' ? 'El corazón de Share2Brain es un bucle Reason-Act-Observe implementado con LangGraph. El agente analiza la consulta, decide qué herramientas usar y observa los resultados hasta resolverla — nunca improvisa.' : 'Share2Brain\'s core is a Reason-Act-Observe loop built with LangGraph. The agent analyzes the query, decides which tools to use and observes results until it resolves the query — it never guesses.'}</span>
      </p>
    </div>

    <HowItWorksLoop
      client:visible
      steps={stepsWithCode}
      loopback={lang === 'es' ? 'se repite hasta resolver · max_iterations' : 'repeats until resolved · max_iterations'}
      note={lang === 'es' ? 'Toda la seguridad y el control viven en el runtime, no en el modelo. El modelo razona; el runtime ejecuta.' : 'All security and control live in the runtime, not the model. The model reasons; the runtime executes.'}
    />
  </div>
</section>
