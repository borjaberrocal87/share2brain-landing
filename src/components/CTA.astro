---
interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
---

<section class="relative overflow-hidden" aria-labelledby="cta-title">
  <div class="max-w-[1180px] mx-auto px-6 py-[clamp(64px,8vw,110px)]">
    <div class="text-center max-w-[46ch] mx-auto">
      <div class="mx-auto mb-6 relative w-[58px] h-[58px] flex items-center justify-center" aria-hidden="true">
        <span class="w-full h-full flex items-center justify-center" style={{ background: 'linear-gradient(150deg, #FFCB6B, #F5A623)', clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)' }}>
          <span class="w-[32px] h-[32px] flex items-center justify-center" style={{ backgroundColor: 'var(--bg)', clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)' }}>
            <span class="w-[11px] h-[11px]" style={{ backgroundColor: '#F5A623', clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)' }} />
          </span>
        </span>
      </div>

      <h2 id="cta-title" class="font-heading font-bold text-[clamp(30px,4.2vw,50px)] tracking-tight leading-[1.08] m-0">
        <span data-i18n="ctaTitle">{lang === 'es' ? 'Despliega tu propio agente hoy' : 'Deploy your own agent today'}</span>
      </h2>

      <p class="text-lg leading-relaxed mt-5 mx-auto" style={{ color: 'var(--muted)' }}>
        <span data-i18n="ctaSub">{lang === 'es' ? 'Open source, self-hosted y verificable. Tu conocimiento nunca sale de tu infraestructura.' : 'Open source, self-hosted and verifiable. Your knowledge never leaves your infrastructure.'}</span>
      </p>

      <div class="flex flex-wrap gap-3 justify-center mt-8">
        <a
          href="https://github.com/borjaberrocal87/chat2brain-landing"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 font-semibold text-[15.5px] no-underline px-6 py-3.5 rounded-xl transition-colors"
          style={{ backgroundColor: 'var(--surface)', color: 'var(--text)', border: '1px solid var(--border-strong)' }}
          aria-label="View Chat2Brain on GitHub (opens in new tab)"
        >
          <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.5 2 2 6.6 2 12.3c0 4.5 2.9 8.4 6.8 9.7.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.4-3.4-1.4-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.6-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.5-1.3.1-2.7 0 0 .8-.3 2.7 1a9.3 9.3 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .6 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10.3 10.3 0 0 0 22 12.3C22 6.6 17.5 2 12 2z"/>
          </svg>
          <span data-i18n="ctaRepo">{lang === 'es' ? 'Ver en GitHub' : 'View on GitHub'}</span>
        </a>
      </div>
    </div>
  </div>
</section>
