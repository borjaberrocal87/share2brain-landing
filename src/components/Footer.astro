---
interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
---

<footer
  style={{
    borderTop: '1px solid var(--border)',
    backgroundColor: 'var(--surface)',
  }}
  role="contentinfo"
>
  <div class="max-w-[1180px] mx-auto px-6 py-[38px] flex flex-wrap gap-5 items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="relative w-[30px] h-[30px] flex-none flex items-center justify-center" style={{ background: 'linear-gradient(150deg, #FFCB6B, #F5A623)', clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)' }} aria-hidden="true">
        <span class="w-[17px] h-[17px] flex items-center justify-center" style={{ backgroundColor: 'var(--surface)', clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)' }}>
          <span class="w-[6px] h-[6px]" style={{ backgroundColor: '#F5A623', clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)' }} />
        </span>
      </span>
      <span class="font-heading font-bold text-lg tracking-tight">Chat2Brain</span>
      <span class="text-[13px] ml-1.5" style={{ color: 'var(--muted)' }}>
        <span data-i18n="footerTag">{lang === 'es' ? 'Agente de conocimiento self-hosted para Discord' : 'Self-hosted knowledge agent for Discord'}</span>
      </span>
    </div>

    <nav class="flex flex-wrap gap-6 text-sm font-medium" style={{ color: 'var(--muted)' }} aria-label="Footer navigation">
      <a href="#docs" class="no-underline transition-colors" style={{ color: 'inherit' }}>
        <span data-i18n="nav.docs">{lang === 'es' ? 'Documentación' : 'Docs'}</span>
      </a>
      <a href="https://github.com/borjaberrocal87/chat2brain-landing" target="_blank" rel="noopener noreferrer" class="no-underline transition-colors" style={{ color: 'inherit' }} aria-label="View Chat2Brain on GitHub (opens in new tab)">
        GitHub
      </a>
      <a href="#" class="no-underline transition-colors" style={{ color: 'inherit' }}>
        <span data-i18n="footerLicense">{lang === 'es' ? 'Licencia MIT' : 'MIT License'}</span>
      </a>
    </nav>
  </div>
</footer>
