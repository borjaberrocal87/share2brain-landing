---
import { Database, FileCheck, Shield } from 'lucide-react';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const icons = [Database, FileCheck, Shield];

const vpEs = [
  { t: 'Tu comunidad ya tiene el conocimiento. Hazlo consultable.', d: 'Share2Brain detecta cada enlace compartido en Discord, descarga y fragmenta su contenido, y lo indexa en una base vectorial con pgvector. La comunidad construye la base de conocimiento sin cambiar sus hábitos.' },
  { t: 'Respuestas verificables, no alucinaciones.', d: 'Cada respuesta incluye citas rastreables al fragmento original: canal, autor, fecha y enlace. El agente opera en streaming para que los miembros vean la respuesta formarse en tiempo real.' },
  { t: 'Tú decides quién ve qué.', d: 'Los roles de Discord se mapean a canales dentro del agente. Cada consulta respeta esos permisos: el miembro solo obtiene respuestas de los canales a los que tiene acceso. RBAC aplicado en cada consulta vectorial.' },
];

const vpEn = [
  { t: 'Your community already has the knowledge. Make it searchable.', d: 'Share2Brain detects every link shared in Discord, fetches and chunks its content, and indexes it in a pgvector knowledge base. Your community builds the knowledge base without changing how they work.' },
  { t: 'Verifiable answers, not hallucinations.', d: 'Every answer includes traceable citations to the original chunk: channel, author, date and link. The agent streams responses so members see the answer form in real time.' },
  { t: 'You decide who sees what.', d: 'Discord roles map to channels inside the agent. Every query respects those permissions: each member only gets answers from channels they can access. RBAC enforced on every vector query.' },
];

const vp = lang === 'es' ? vpEs : vpEn;
---

<section id="producto" class="max-w-[1180px] mx-auto px-6 py-[clamp(40px,6vw,72px)]" aria-labelledby="values-title">
  <div class="mb-[38px]">
    <p class="font-mono text-sm font-semibold mb-3 tracking-wide" style={{ color: 'var(--accent-ink)' }}>
      // <span data-i18n="valuesKicker">{lang === 'es' ? 'por qué elegir Share2Brain' : 'why Share2Brain'}</span>
    </p>
    <h2 
      id="values-title"
      class="font-heading font-bold text-[clamp(28px,3.6vw,42px)] tracking-tight m-0 max-w-[18ch]"
    >
      <span data-i18n="valuesTitle">{lang === 'es' ? 'Conocimiento que muere en el scroll, respuestas que puedes verificar' : 'Knowledge that dies in the scroll, answers you can verify'}</span>
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-[18px]" role="list">
    {vp.map((item, i) => {
      const Icon = icons[i];
      const tKey = `vp.${i}.t`;
      const dKey = `vp.${i}.d`;
      return (
        <div
          class="rounded-[var(--radius)] p-7"
          style={{
            backgroundColor: 'var(--surface)',
            border: '1px solid var(--border)',
          }}
          role="listitem"
        >
          <span
            class="flex w-[46px] h-[46px] clip-path-hex items-center justify-center mb-[18px]"
            style={{
              backgroundColor: 'var(--accent-soft)',
              color: 'var(--accent-ink)',
            }}
            aria-hidden="true"
          >
            <Icon size={22} strokeWidth={1.8} />
          </span>
          <h3 class="font-heading font-semibold text-xl tracking-tight m-0 mb-2.5">
            <span data-i18n={tKey}>{item.t}</span>
          </h3>
          <p class="m-0 leading-relaxed text-[15px]" style={{ color: 'var(--muted)' }}>
            <span data-i18n={dKey}>{item.d}</span>
          </p>
        </div>
      );
    })}
  </div>
</section>
