---
import { ThemeToggle } from './ThemeToggle';
import { LanguageToggle } from './LanguageToggle';
import { MobileMenu } from './MobileMenu';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const navItems = [
  { href: '#producto', label: lang === 'es' ? 'Producto' : 'Product' },
  { href: '#features', label: lang === 'es' ? 'Características' : 'Features' },
  { href: '#how', label: lang === 'es' ? 'Cómo funciona' : 'How it works' },
  { href: '#docs', label: lang === 'es' ? 'Documentación' : 'Docs' },
  { href: '#stack', label: lang === 'es' ? 'Stack' : 'Stack' },
];
---

<header
  class="sticky top-0 z-50"
  style={{
    background: 'var(--header-bg)',
    borderBottom: '1px solid var(--border)',
    WebkitBackdropFilter: 'saturate(180%) blur(14px)',
    backdropFilter: 'saturate(180%) blur(14px)',
  }}
  role="banner"
>
  <div class="max-w-[1180px] mx-auto px-4 sm:px-6 h-[var(--header-h)] flex items-center justify-between gap-3 sm:gap-4">
    {/* Logo */}
    <a
      href="#top"
      class="flex items-center gap-2 sm:gap-3 no-underline min-w-0"
      style={{ color: 'var(--text)' }}
      aria-label="Share2Brain - Go to top"
    >
      <span
        class="relative w-[34px] h-[34px] flex-none flex items-center justify-center"
        style={{
          background: 'linear-gradient(150deg, #FFCB6B, #F5A623)',
          clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)',
        }}
        aria-hidden="true"
      >
        <span
          class="w-[19px] h-[19px] flex items-center justify-center"
          style={{
            backgroundColor: 'var(--bg)',
            clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)',
          }}
        >
          <span
            class="w-[7px] h-[7px]"
            style={{
              backgroundColor: '#F5A623',
              clipPath: 'polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)',
            }}
          />
        </span>
      </span>
      <span class="font-heading font-bold text-xl tracking-tight hidden min-[360px]:inline">Share2Brain</span>
    </a>

    {/* Desktop Navigation */}
    <nav 
      class="daemon-nav hidden nav:flex items-center gap-7 font-medium"
      aria-label="Main navigation"
      style="font-size: 14.5px;"
    >
      {navItems.map((item) => (
        <a
          href={item.href}
          class="no-underline transition-colors text-[color:var(--muted)] hover:text-[color:var(--text)]"
        >
          <span data-i18n={`nav.${item.href === '#producto' ? 'producto' : item.href === '#features' ? 'features' : item.href === '#how' ? 'how' : item.href === '#docs' ? 'docs' : 'stack'}`}>
            {item.label}
          </span>
        </a>
      ))}
    </nav>

    {/* Actions */}
    <div class="flex items-center gap-2 sm:gap-3 flex-none" role="group" aria-label="Theme and language controls">
      <LanguageToggle client:idle initialLang={lang} />
      <ThemeToggle client:idle />
      <MobileMenu client:idle items={navItems} />
    </div>
  </div>
</header>
