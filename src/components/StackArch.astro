---
interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const stackEs = [
  { n: 'TypeScript / Node.js', r: 'Backend y runtime' },
  { n: 'LangChain.js', r: 'Orquestación del agente' },
  { n: 'Postgres + pgvector', r: 'Datos y búsqueda vectorial' },
  { n: 'Redis Streams', r: 'Cola de eventos · outbox' },
  { n: 'React + TypeScript', r: 'App y panel de admin' },
  { n: 'Docker Compose', r: 'Empaquetado en un comando' },
  { n: 'Sentry · Pino · Prometheus', r: 'Observabilidad' },
  { n: 'Astro', r: 'Landing estática' },
];

const stackEn = [
  { n: 'TypeScript / Node.js', r: 'Backend and runtime' },
  { n: 'LangChain.js', r: 'Agent orchestration' },
  { n: 'Postgres + pgvector', r: 'Data and vector search' },
  { n: 'Redis Streams', r: 'Event queue · outbox' },
  { n: 'React + TypeScript', r: 'App and admin panel' },
  { n: 'Docker Compose', r: 'Packaged in one command' },
  { n: 'Sentry · Pino · Prometheus', r: 'Observability' },
  { n: 'Astro', r: 'Static landing' },
];

const stack = lang === 'es' ? stackEs : stackEn;

const archLayersEs = [
  { n: 'Interface', d: 'Controllers · UI React' },
  { n: 'Application', d: 'Use cases · runtime' },
  { n: 'Domain', d: 'Entidades · eventos' },
  { n: 'Infrastructure', d: 'Postgres · LangChain · Redis' },
];

const archLayersEn = [
  { n: 'Interface', d: 'Controllers · React UI' },
  { n: 'Application', d: 'Use cases · runtime' },
  { n: 'Domain', d: 'Entities · events' },
  { n: 'Infrastructure', d: 'Postgres · LangChain · Redis' },
];

const archLayers = lang === 'es' ? archLayersEs : archLayersEn;
---

<section
  id="stack"
  style={{
    backgroundColor: 'var(--surface-2)',
    borderTop: '1px solid var(--border)',
  }}
  aria-labelledby="stack-title"
>
  <div class="max-w-[1180px] mx-auto px-6 py-[clamp(56px,7vw,96px)]">
    <div class="mb-[38px]">
      <p class="font-mono text-sm font-semibold mb-3 tracking-wide" style={{ color: 'var(--accent-ink)' }}>
        // <span data-i18n="stackKicker">{lang === 'es' ? 'stack tecnológico' : 'tech stack'}</span>
      </p>
      <h2 
        id="stack-title"
        class="font-heading font-bold text-[clamp(28px,3.6vw,42px)] tracking-tight m-0"
      >
        <span data-i18n="stackTitle">{lang === 'es' ? 'Construido sobre piezas sólidas' : 'Built on solid foundations'}</span>
      </h2>
    </div>

    {/* Technology grid */}
    <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-3.5 mb-16" role="list" aria-label="Technology stack">
      {stack.map((item) => (
        <div
          class="rounded-[var(--radius)] p-5"
          style={{
            backgroundColor: 'var(--surface)',
            border: '1px solid var(--border)',
          }}
          role="listitem"
        >
          <div class="font-heading font-semibold text-base mb-1">{item.n}</div>
          <div class="text-[13.5px]" style={{ color: 'var(--muted)' }}>{item.r}</div>
        </div>
      ))}
    </div>

    {/* Architecture diagrams */}
    <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-6 items-stretch">
      {/* Clean Architecture */}
      <div
        class="rounded-[var(--radius)] p-7"
        style={{
          backgroundColor: 'var(--surface)',
          border: '1px solid var(--border)',
        }}
      >
        <h3 class="font-heading font-semibold text-xl tracking-tight m-0 mb-1.5">
          <span data-i18n="archTitle">{lang === 'es' ? 'Clean Architecture' : 'Clean Architecture'}</span>
        </h3>
        <p class="text-sm m-0 mb-5 leading-relaxed" style={{ color: 'var(--muted)' }}>
          <span data-i18n="archSub">{lang === 'es' ? 'Separación en capas con dependencias hacia adentro.' : 'Layered separation with inward dependencies.'}</span>
        </p>
        <div class="flex flex-col gap-2" role="list" aria-label="Architecture layers">
          {archLayers.map((layer) => (
            <div
              class="rounded-[calc(var(--radius)-2px)] p-3.5 px-4"
              style={{ border: '1px solid var(--border)' }}
              role="listitem"
            >
              <div class="flex items-center justify-between gap-2.5">
                <span class="font-mono font-semibold text-sm">{layer.n}</span>
                <span class="text-[12.5px] text-right" style={{ color: 'var(--muted)' }}>{layer.d}</span>
              </div>
            </div>
          ))}
        </div>
        <p class="flex items-center gap-2 mt-4 text-[13px]" style={{ color: 'var(--muted)' }}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent-ink)" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
            <path d="M12 19V5M5 12l7-7 7 7"/>
          </svg>
          <span data-i18n="archRule">{lang === 'es' ? 'Domain no depende de nada; las capas externas implementan sus puertos.' : 'Domain depends on nothing; outer layers implement its ports.'}</span>
        </p>
      </div>

      {/* Event-Driven */}
      <div
        class="rounded-[var(--radius)] p-7"
        style={{
          backgroundColor: 'var(--surface)',
          border: '1px solid var(--border)',
        }}
      >
        <h3 class="font-heading font-semibold text-xl tracking-tight m-0 mb-1.5">
          <span data-i18n="eventTitle">{lang === 'es' ? 'Event-Driven' : 'Event-Driven'}</span>
        </h3>
        <p class="text-sm m-0 mb-6 leading-relaxed" style={{ color: 'var(--muted)' }}>
          <span data-i18n="eventSub">{lang === 'es' ? 'La indexación pesada se desacopla del runtime con Redis Streams y el patrón Outbox.' : 'Heavy indexing is decoupled from the runtime with Redis Streams and the Outbox pattern.'}</span>
        </p>
        <div class="flex items-stretch gap-2.5" role="img" aria-label="Event-driven architecture flow: Producer → Redis Streams → Consumer">
          <div class="flex-1 text-center rounded-[calc(var(--radius)-2px)]" style={{ backgroundColor: 'var(--accent-soft)', border: '1px solid var(--accent-line)', padding: '18px 10px' }}>
            <div class="flex justify-center mb-2" style={{ color: 'var(--accent-ink)' }}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="6" rx="1.5"/><rect x="3" y="14" width="18" height="6" rx="1.5"/>
              </svg>
            </div>
            <div class="font-heading font-semibold text-sm"><span data-i18n="evProducer">{lang === 'es' ? 'Productor' : 'Producer'}</span></div>
            <div class="text-[11.5px] mt-0.5" style={{ color: 'var(--muted)' }}>Admin API</div>
          </div>
          <div class="flex items-center" style={{ color: 'var(--accent-ink)' }} aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>
          <div class="flex-1 text-center rounded-[calc(var(--radius)-2px)]" style={{ backgroundColor: 'var(--code-bg)', padding: '18px 10px' }}>
            <div class="flex justify-center mb-2" style={{ color: 'var(--accent)' }}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
                <path d="M4 7c0 1.7 3.6 3 8 3s8-1.3 8-3-3.6-3-8-3-8 1.3-8 3z"/>
                <path d="M4 7v10c0 1.7 3.6 3 8 3s8-1.3 8-3V7"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>
              </svg>
            </div>
            <div class="font-heading font-semibold text-sm text-white">Redis Streams</div>
            <div class="text-[11.5px] mt-0.5" style={{ color: 'var(--code-comment)' }}>Outbox</div>
          </div>
          <div class="flex items-center" style={{ color: 'var(--accent-ink)' }} aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>
          <div class="flex-1 text-center rounded-[calc(var(--radius)-2px)]" style={{ backgroundColor: 'var(--accent-soft)', border: '1px solid var(--accent-line)', padding: '18px 10px' }}>
            <div class="flex justify-center mb-2" style={{ color: 'var(--accent-ink)' }}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
                <path d="M12 2v4M12 2 9 5M12 2l3 3"/><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M9 13h6M9 16h4"/>
              </svg>
            </div>
            <div class="font-heading font-semibold text-sm"><span data-i18n="evConsumer">{lang === 'es' ? 'Consumidor' : 'Consumer'}</span></div>
            <div class="text-[11.5px] mt-0.5" style={{ color: 'var(--muted)' }}>Indexer</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mt-4">
          <span class="font-mono text-[11.5px] px-2.5 py-1.5 rounded-full" style={{ backgroundColor: 'var(--surface-2)', color: 'var(--muted)' }}>knowledge.source.added</span>
          <span class="font-mono text-[11.5px] px-2.5 py-1.5 rounded-full" style={{ backgroundColor: 'var(--surface-2)', color: 'var(--muted)' }}>reindex.requested</span>
        </div>
      </div>
    </div>
  </div>
</section>
