---
import { DocsTabs } from './DocsTabs';
import { translations } from '../i18n';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

// Single source of truth: documentation groups live in the i18n files. Only the
// page locale's groups are passed, so each page's HTML carries one language.
const docSections = translations[lang].docSections;
---

<section id="docs" class="max-w-[1180px] mx-auto px-6 py-[clamp(56px,7vw,96px)]" aria-labelledby="docs-title">
  <div class="mb-[38px] max-w-[60ch]">
    <p class="font-mono text-sm font-semibold mb-3 tracking-wide" style={{ color: 'var(--accent-ink)' }}>
      // <span data-i18n="docsKicker">{lang === 'es' ? 'documentación' : 'documentation'}</span>
    </p>
    <h2 
      id="docs-title"
      class="font-heading font-bold text-[clamp(28px,3.6vw,42px)] tracking-tight m-0 mb-3.5"
    >
      <span data-i18n="docsTitle">{lang === 'es' ? 'Documentación navegable' : 'Browsable documentation'}</span>
    </h2>
    <p class="text-base leading-relaxed m-0" style={{ color: 'var(--muted)' }}>
      <span data-i18n="docsSub">{lang === 'es' ? 'Todo lo que necesitas para desplegar y operar tu instancia, organizado por secciones.' : 'Everything you need to deploy and operate your instance, organized by section.'}</span>
    </p>
  </div>

  <DocsTabs client:visible sections={docSections} />
</section>
