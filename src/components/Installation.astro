---
import { CodeBlock } from './CodeBlock';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const installSteps = [
  {
    code: `$ git clone github.com/borjaberrocal87/share2brain
$ cd share2brain`,
  },
  {
    code: `$ cp .env.example .env
$ cp Share2Brain.config.yml.example Share2Brain.config.yml`,
  },
  {
    code: `$ docker compose up -d
✓ 7 services · http://localhost`,
  },
];

const titlesEs = ['Clona el repositorio', 'Configura variables de entorno', 'Levanta los 7 servicios'];
const titlesEn = ['Clone the repository', 'Configure environment variables', 'Start all 7 services'];
const titles = lang === 'es' ? titlesEs : titlesEn;
---

<section
  id="install"
  style={{
    backgroundColor: 'var(--surface-2)',
    borderTop: '1px solid var(--border)',
    borderBottom: '1px solid var(--border)',
  }}
  aria-labelledby="install-title"
>
  <div class="max-w-[1180px] mx-auto px-6 py-[clamp(56px,7vw,96px)]">
    <div class="mb-10 max-w-[60ch]">
      <p class="font-mono text-sm font-semibold mb-3 tracking-wide" style={{ color: 'var(--accent-ink)' }}>
        // <span data-i18n="installKicker">{lang === 'es' ? 'instalación' : 'installation'}</span>
      </p>
      <h2 
        id="install-title"
        class="font-heading font-bold text-[clamp(28px,3.6vw,42px)] tracking-tight m-0 mb-3.5"
      >
        <span data-i18n="installTitle">{lang === 'es' ? 'Un comando, 7 servicios, cero dependencias externas' : 'One command, 7 services, zero external dependencies'}</span>
      </h2>
      <p class="text-base leading-relaxed m-0" style={{ color: 'var(--muted)' }}>
        <span data-i18n="installSub">{lang === 'es' ? 'Un solo docker-compose up levanta el backend, el bot de Discord, los workers de indexación, la aplicación web (búsqueda, chat, documentos y estadísticas), Postgres con pgvector, Redis y nginx. Sin SaaS, sin suscripciones.' : 'A single docker-compose up starts the backend, the Discord bot, the indexing workers, the web app (search, chat, documents and stats), Postgres with pgvector, Redis and nginx. No SaaS, no subscriptions.'}</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(290px,1fr))] gap-[18px]" role="list">
      {titles.map((title, i) => (
        <div
          class="rounded-[var(--radius)] overflow-hidden"
          style={{
            backgroundColor: 'var(--surface)',
            border: '1px solid var(--border)',
          }}
          role="listitem"
        >
          <div class="flex items-center gap-3 px-5 pt-5 pb-4">
            <span
              class="font-mono font-semibold text-sm clip-path-hex w-8 h-8 flex items-center justify-center"
              style={{
                color: 'var(--accent-ink)',
                backgroundColor: 'var(--accent-soft)',
              }}
              aria-hidden="true"
            >
              {i + 1}
            </span>
            <h3 class="font-heading font-semibold text-base m-0">
              <span data-i18n={`installSteps.${i}.t`}>{title}</span>
            </h3>
          </div>
          <CodeBlock code={installSteps[i].code} client:visible />
        </div>
      ))}
    </div>
  </div>
</section>
