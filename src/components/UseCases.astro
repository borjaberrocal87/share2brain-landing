---
import { MessageCircle, Users, Headphones, Search } from 'lucide-react';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const icons = [MessageCircle, Users, Headphones, Search];

const casesEs = [
  { t: 'Elimina las preguntas repetidas', d: 'Las dudas que se repiten cada semana se responden solas, citando el recurso exacto. Tu equipo de moderación se libera para tareas de mayor valor.' },
  { t: 'Onboarding sin fricción', d: 'Los nuevos miembros encuentran reglas, guías y respuestas sin esperar a un moderador. El agente conoce todo lo que se ha compartido en los canales que tienen acceso.' },
  { t: 'Soporte técnico con fuentes', d: 'Preguntas sobre tu producto, API o configuración respondidas al instante, citando la documentación o el hilo original. Precisión sin alucinaciones.' },
  { t: 'Busca en el histórico', d: 'Recupera conversaciones, decisiones y recursos compartidos en hilos y canales usando búsqueda semántica. No necesitas recordar palabras exactas.' },
];

const casesEn = [
  { t: 'Eliminate recurring questions', d: 'Questions that repeat every week answer themselves, citing the exact resource. Your mod team is freed for higher-value work.' },
  { t: 'Frictionless onboarding', d: 'New members find rules, guides and answers without waiting for a moderator. The agent knows everything shared in channels they can access.' },
  { t: 'Technical support with sources', d: 'Questions about your product, API or config answered instantly, citing the original docs or thread. Accuracy without hallucination.' },
  { t: 'Search your history', d: 'Recover conversations, decisions and resources shared in threads and channels using semantic search. No need to recall exact wording.' },
];

const cases = lang === 'es' ? casesEs : casesEn;
---

<section class="max-w-[1180px] mx-auto px-6 py-[clamp(56px,7vw,96px)]" aria-labelledby="cases-title">
  <div class="mb-[38px]">
    <p class="font-mono text-sm font-semibold mb-3 tracking-wide" style={{ color: 'var(--accent-ink)' }}>
      // <span data-i18n="casesKicker">{lang === 'es' ? 'casos de uso' : 'use cases'}</span>
    </p>
    <h2 
      id="cases-title"
      class="font-heading font-bold text-[clamp(28px,3.6vw,42px)] tracking-tight m-0"
    >
      <span data-i18n="casesTitle">{lang === 'es' ? 'Resultados reales para comunidades reales' : 'Real results for real communities'}</span>
    </h2>
  </div>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(255px,1fr))] gap-4" role="list">
    {cases.map((item, i) => {
      const Icon = icons[i];
      return (
        <div
          class="rounded-[var(--radius)] p-6"
          style={{
            backgroundColor: 'var(--surface)',
            border: '1px solid var(--border)',
          }}
          role="listitem"
        >
          <div
            class="w-[34px] h-[34px] clip-path-hex flex items-center justify-center mb-4"
            style={{
              backgroundColor: 'var(--accent-soft)',
              color: 'var(--accent-ink)',
            }}
            aria-hidden="true"
          >
            <Icon size={17} strokeWidth={2} />
          </div>
          <h3 class="font-heading font-semibold text-lg tracking-tight m-0 mb-2">
            <span data-i18n={`cases.${i}.t`}>{item.t}</span>
          </h3>
          <p class="m-0 leading-relaxed text-[14.5px]" style={{ color: 'var(--muted)' }}>
            <span data-i18n={`cases.${i}.d`}>{item.d}</span>
          </p>
        </div>
      );
    })}
  </div>
</section>
