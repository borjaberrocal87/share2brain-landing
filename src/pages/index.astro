---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ValueProps from '../components/ValueProps.astro';
import HowItWorks from '../components/HowItWorks.astro';
import UseCases from '../components/UseCases.astro';
import Installation from '../components/Installation.astro';
import Docs from '../components/Docs.astro';
import StackArch from '../components/StackArch.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

// Default to Spanish, will be updated client-side by i18n-client.ts
const lang = 'es';
---

<BaseLayout title="Hivly - AI Agent for Discord Communities">
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div id="top">
    <Header lang={lang} />
    <main id="main-content" style="overflow-x: hidden; max-width: 100vw;">
      <Hero lang={lang} />
      <ValueProps lang={lang} />
      <HowItWorks lang={lang} />
      <UseCases lang={lang} />
      <Installation lang={lang} />
      <Docs lang={lang} />
      <StackArch lang={lang} />
      <CTA lang={lang} />
    </main>
    <Footer lang={lang} />
  </div>
</BaseLayout>
