---
import '../styles/global.css';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { DEFAULT_LOCALE, localeAlternates, localePath } from '../i18n/routing';
import type { Language } from '../i18n';

interface Props {
  title: string;
  lang: Language;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Share2Brain — Knowledge Agent for Discord Communities',
  lang,
  description = 'Self-hosted AI agent that indexes links shared in your Discord community and answers members in natural language — with verifiable citations, streaming responses and role-based access control. Open source, MIT license.',
  canonical,
  ogImage = 'https://share2brain.app/og-image.svg'
} = Astro.props;

const siteName = 'Share2Brain';
const twitterHandle = '@share2brain';
const gaId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;

// Per-locale SEO: each page canonicalizes to its own locale URL and declares
// reciprocal hreflang alternates so search engines index each language
// independently. `og:locale` uses full locale-region codes.
const OG_LOCALES: Record<Language, string> = { es: 'es_ES', en: 'en_US' };
const canonicalUrl = canonical ?? new URL(localePath(lang), Astro.site).href;
const alternates = localeAlternates().map((alt) => ({
  locale: alt.locale,
  href: new URL(alt.url, Astro.site).href,
}));
const xDefaultHref = new URL(localePath(DEFAULT_LOCALE), Astro.site).href;
const ogLocale = OG_LOCALES[lang];
const ogLocaleAlternates = alternates
  .filter((alt) => alt.locale !== lang)
  .map((alt) => OG_LOCALES[alt.locale]);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Localized alternates (hreflang) for correct per-language indexing -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.locale} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <meta property="twitter:site" content={twitterHandle} />
    <meta property="twitter:creator" content={twitterHandle} />

    <GoogleAnalytics measurementId={gaId} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    
    <!-- Theme detection script to prevent FOUC -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = savedTheme || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Share2Brain",
      "description": description,
      "url": canonicalUrl,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Linux, Docker",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "softwareVersion": "1.0.0",
      "screenshot": ogImage,
      "featureList": [
        "Automatic indexing of links shared in Discord channels",
        "Semantic search with pgvector",
        "RAG agent chat with streaming responses and cited sources",
        "Per-channel RBAC via Discord roles",
        "Per-member read tracking with unread badges",
        "Knowledge stats (activity, coverage, top contributors)",
        "Slack and Telegram notifications",
        "Discord OAuth2 login with optional guest access",
        "One-command Docker Compose deployment (7 services)"
      ],
      "requirements": "Node.js 24+, Docker, PostgreSQL with pgvector",
      "license": "https://opensource.org/licenses/MIT",
      "softwareHelp": {
        "@type": "CreativeWork",
        "url": "https://share2brain.app/docs"
      },
      "maintainer": {
        "@type": "Organization",
      "name": "Share2Brain",
        "url": "https://github.com/borjaberrocal87/share2brain"
      }
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
